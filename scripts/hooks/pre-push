#!/usr/bin/env bash
# Guardrail versionado: roda lint rapido (ktlint+detekt) antes do push e lembra
# de rodar a suite de testes completa -- nao so o modulo tocado.
#
# Motivo: a PR #869 quase mergeou com Unit Tests quebrado porque so o modulo
# tocado foi testado localmente antes do push, nao a suite inteira. Ktlint e
# Detekt sao os dois checks ja obrigatorios no branch protection de main --
# rodar aqui pega o mesmo erro minutos antes, sem esperar o CI.
#
# Override consciente: PUSH_SKIP_LOCAL_CHECKS=1 git push ...
set -euo pipefail

if [ "${PUSH_SKIP_LOCAL_CHECKS:-0}" = "1" ]; then
  exit 0
fi

has_android_changes=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base="$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "$local_sha~20")"
  else
    base="$remote_sha"
  fi
  if git diff --name-only "$base" "$local_sha" 2>/dev/null | grep -q '^android/'; then
    has_android_changes=1
  fi
done

if [ "$has_android_changes" = "0" ]; then
  exit 0
fi

echo "==> pre-push: rodando ktlint + detekt (android/)..."
if ! (cd android && ./gradlew ktlintCheck detekt --quiet); then
  echo "BLOQUEADO: ktlint/detekt falhou. Corrija antes do push." >&2
  echo "Override consciente: PUSH_SKIP_LOCAL_CHECKS=1 git push ..." >&2
  exit 1
fi

echo ""
echo "LEMBRETE: rode a suite COMPLETA de testes antes de confiar neste push:"
echo "  cd android && ./gradlew test"
echo "(nao so o modulo tocado -- foi exatamente esse erro que quase causou merge quebrado na PR #869)"
echo ""
exit 0
