# =============================================================================
# SignallQ Admin Panel — Variáveis de ambiente
# Copie para .env.local e preencha os valores reais.
# NUNCA commitar .env.local no git.
# =============================================================================

# --- Modo de operação ---
# true  = dados mockados locais (desenvolvimento sem backend)
# false = chamadas reais ao Admin Worker
VITE_ENABLE_MOCKS=true

# --- Admin API Worker (Cloudflare) ---
# URL do worker que substituiu o esquilo-invest-web.
# Deixe vazio enquanto VITE_ENABLE_MOCKS=true.
# Preencher após: npx wrangler deploy (dentro de signallq-admin-worker/)
VITE_ADMIN_API_BASE_URL=

# Bearer token para autenticar no Admin Worker.
# Deve ser idêntico ao secret ADMIN_SECRET configurado no worker:
#   npx wrangler secret put ADMIN_SECRET
VITE_ADMIN_API_SECRET=

# --- Firebase Web SDK (painel React) ---
# Obter em: Firebase Console → Project Settings → General → Web apps → Add app
VITE_FIREBASE_API_KEY=AIzaSyBMLpPbjVRMSqm8SAafl6jFtoON1Hcqbos
VITE_FIREBASE_AUTH_DOMAIN=device-streaming-ef179de4.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=device-streaming-ef179de4
VITE_FIREBASE_STORAGE_BUCKET=device-streaming-ef179de4.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=620840247394
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Geral ---
VITE_APP_ENV=production
VITE_API_TIMEOUT_MS=15000
