# SignallQ Admin Console Environment Variables

# Base URL for the SignallQ Admin backend gateway API
VITE_ADMIN_API_BASE_URL=https://api.signallq.internal/v1

# Controls whether telemetry should be served from static high-fidelity mocks or real API points
VITE_ENABLE_MOCKS=true

# Development or production flag
VITE_APP_ENV=production
